<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
 <mapper namespace = "com.kh.spring.board.model.dao.BoardMapper">
 
 	<select id="selectTotalCount"
 			resultType="_int">
 		SELECT
 			COUNT(*)
 		FROM
 			BOARD
 		WHERE
 			STATUS = 'Y'
 	</select>
 
 	<select id="findAll"
 			resultType="com.kh.spring.board.model.dto.BoardDto">
 			<include refid="boardColumn"/>
 		
 			FROM
 				BOARD
 			WHERE
 				STATUS = 'Y'
 			ORDER
 			   BY
 				BOARD_NO DESC
 			
 			</select>
 
 	<insert id="save">
 		INSERT
 			INTO
 				BOARD
 		VALUES
 			(
 			SEQ_BNO.NEXTVAL
 			,#{boardTitle}
 			,#{boardWriter}
 			,#{boardContent}
 			,#{originName}
 			,#{changeName}
 			,0
 			,DEFAULT
 			,DEFAULT
 			)
 	</insert>
 	
 	<update id="increaseCount">
 		UPDATE
 			BOARD
 		SET
 			COUNT = COUNT +1
 		WHERE
 			BOARD_NO = #{boardNo}
 		AND
 			STATUS = 'Y'
 	</update>
 	
 	<sql id="boardColumn">
 			SELECT
 				BOARD_NO
 				,BOARD_TITLE
 				,BOARD_WRITER
 				,COUNT
 				,TO_CHAR(CREATE_DATE,'YYYY-MM-DD') as createDate
 				,CHANGE_NAME
 	</sql>
 	
 	<select id="findByBoardNo"
 			resultType="com.kh.spring.board.model.dto.BoardDto">
 		<include refid="boardColumn"/>
 		,BOARD_Content
 		,ORIGIN_NAME
 		FROM
 			BOARD
 		WHERE
 			STATUS = 'Y'
 		AND
 			BOARD_NO = #{boardNo}
 	</select>
 	
 	<select id="findByKeywordCount"
 			resultType="_int">
 		select
 			count(*)
 		from
 			board
 		where
 			status = 'Y'
 	<if test="condition == 'content'">
 		and
 			board_content
 	</if>		
 	<if test="condition == 'writer'">
 		and
 			board_writer
 	</if>
 	<if test="condition == 'title'">
 		and
 			board_title
 	</if>
 		like '%' || #{keyword} || '%'					
 	</select>
 	
 	<select	id="findByKeyword"
 			resultType="com.kh.spring.board.model.dto.BoardDto">
 		<include refid="boardColumn"/>
 		from
 			board
 		where
 			status = 'Y'
 		<choose>
 		<when test="condition == 'content'">
 		and
 			board_content
 		</when>
 		<when test="condition == 'writer'">
 		and
 			board_writer
 		</when>
 		<otherwise>
 		and
 			board_title
 		</otherwise>
 		</choose>
 		like '%' || #{keyword} || '%'
 		order
 			by
 				board_no desc
 	</select>
 	<!-- OFFSET ${offset} ROWS FETCH NEXT #{limit} ROWS ONLY -->
 
 </mapper>