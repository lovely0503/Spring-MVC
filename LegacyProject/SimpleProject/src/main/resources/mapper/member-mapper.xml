<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  <mapper namespace="memberMapper">
  
  	<select id="login" resultType="com.kh.spring.member.model.dto.MemberDto">
  		SELECT
  			USER_ID
  			,USER_NAME
  			,EMAIL
  			,ENROLL_DATE
  		FROM
  			MEMBER
  		WHERE
  			USER_ID = #{userId}
  		AND
  			USER_PWD = #{userPwd}
  		AND
  			STATUS = 'Y'
  	</select>
  	
  	<insert id="signup">
  		INSERT
  			INTO
  			MEMBER
  				(
  				USER_ID
  				,USER_PWD
  				,USER_NAME
  				,EMAIL
  				)
  			VALUES
  				(
  				#{userId}
  				,#{userPwd}
  				,#{userName}
  				,#{email}
  				)
  	</insert>
  
  </mapper>